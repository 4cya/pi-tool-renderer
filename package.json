{
  "name": "pi-tool-renderer",
  "version": "1.6.3",
  "description": "Compact Claude/opencode-style renderers for Pi tools with rich diffs, apply_patch, generic/MCP rendering, and optional global chrome.",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi",
    "coding-agent",
    "tools",
    "renderer",
    "shiki",
    "diff",
    "mcp",
    "apply-patch"
  ],
  "pi": {
    "extensions": [
      "./extensions/tool-renderer.ts"
    ],
    "image": "https://raw.githubusercontent.com/4cya/pi-tool-renderer/main/assets/tool-batch.png"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "files": [
    "extensions/",
    "assets/",
    "README.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/4cya/pi-tool-renderer.git"
  },
  "homepage": "https://github.com/4cya/pi-tool-renderer",
  "bugs": {
    "url": "https://github.com/4cya/pi-tool-renderer/issues"
  },
  "author": "4cya",
  "engines": {
    "node": ">=22.19.0"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    }
  }
}
